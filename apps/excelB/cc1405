@echo off
title Rain with Maximum Spaces
color 0A
setlocal enabledelayedexpansion

:loop
set "line="
for /l %%i in (1,1,80) do (
    set /a rand=!random! %% 15
    if !rand!==0 (
        set "line=!line!0"
    ) else if !rand!==1 (
        set "line=!line!1"
    ) else (
        set "line=!line! "
    )
)
echo %line%
goto loop
